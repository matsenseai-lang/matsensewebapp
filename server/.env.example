# Copy to .env and fill values for local testing
PORT=3000
# For production on Railway set DATABASE_URL (postgres)
# DATABASE_URL=postgres://user:pass@host:port/dbname

# SMTP (Hostinger example)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=Matsenseai@1122
SMTP_PASS=your_smtp_password_from_hostinger

FROM_EMAIL=info@matsenseai.co.uk
ADMIN_EMAILS=matsenseai@gmail.com,info@matsenseai.co.uk

# Admin login (use ADMIN_PASS_HASH for bcrypt, or ADMIN_PASS for plain text)
ADMIN_USER=admin
# ADMIN_PASS=changeme  # plain text (not recommended)
ADMIN_PASS_HASH=$2a$10$Mx3/AaNKChbo2Seu3IrFf.filDdab.Crtqz1VLT4CPktYD4SpqHFm  # bcrypt hash of "Matsenseai@1122" (recommended)
ADMIN_JWT_SECRET=replace_this_with_random_string_for_production
